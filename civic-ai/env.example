# ── AI model ─────────────────────────────────────────────────────────────────
# Production: use a self-hosted open-source model (Llama 3, Mistral, Falcon)
# so citizens and auditors can inspect the exact model weights.
# For development/staging: the Anthropic API is used as a drop-in.
ANTHROPIC_API_KEY=

# Model selection. Swap this for your open-source model endpoint in production.
# Open-source self-hosted: set AI_PROVIDER=ollama and AI_BASE_URL=http://localhost:11434
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514
# AI_PROVIDER=ollama
# AI_MODEL=llama3:70b
# AI_BASE_URL=http://localhost:11434

# ── IPFS ─────────────────────────────────────────────────────────────────────
# Pinata is used for IPFS pinning. Replace with your own IPFS node in production.
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Blockchain ────────────────────────────────────────────────────────────────
RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY
AI_ORACLE_PRIVATE_KEY=

# Contract addresses (from civic-qv deployment)
QV_CONTRACT_ADDRESS=
IDENTITY_VERIFIER_ADDRESS=

# ── Oversight panel ───────────────────────────────────────────────────────────
# Minimum number of panel members who must approve before on-chain submission
OVERSIGHT_APPROVAL_THRESHOLD=3
# How long the panel has to review (seconds) before auto-escalation
OVERSIGHT_REVIEW_WINDOW_SECONDS=172800

# ── Service ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
