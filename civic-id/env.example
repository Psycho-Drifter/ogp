# ─────────────────────────────────────────────────────────────
#  civic-id environment config
#  Copy this to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# XRPL network — use testnet for development, mainnet for production
XRPL_NETWORK=wss://s.altnet.rippletest.net:51233

# Issuer account — generated by setup-issuer.ts on first run
# This is the government/authority wallet that signs all identity NFTs
ISSUER_ADDRESS=
ISSUER_SECRET=

# Transfer fee (0 = no royalty, max 50000 = 50%)
# For governance NFTs this should be 0
NFT_TRANSFER_FEE=0

# Taxon — a numeric namespace for your NFT collection
# Use a fixed value so all civic identity NFTs share the same taxon
CIVIC_IDENTITY_TAXON=1000

# Metadata URI base — points to your identity metadata service
# The full URI per token will be: METADATA_BASE_URI/{citizenId}
METADATA_BASE_URI=https://id.yourcivicplatform.org/v1/identity/
