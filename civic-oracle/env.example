# ── XRPL ─────────────────────────────────────────────────────────────────────
XRPL_NETWORK=wss://s.altnet.rippletest.net:51233
ISSUER_ADDRESS=          # the civic identity issuer wallet from civic-id
CIVIC_NFT_TAXON=1000     # must match civic-id config

# ── Polygon ───────────────────────────────────────────────────────────────────
RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY
ORACLE_PRIVATE_KEY=      # multi-sig in production; single key for dev

# Contract addresses from civic-qv deployment
IDENTITY_VERIFIER_ADDRESS=

# ── Oracle config ─────────────────────────────────────────────────────────────
# Which shard ID this oracle manages (1=Earth, 2=Mars, etc.)
SHARD_ID=1
SHARD_NAME=Earth

# How many voice credits each verified citizen receives per cycle
VOICE_CREDITS_PER_CITIZEN=100

# How often to rebuild the Merkle tree from the DB (milliseconds)
# 3600000 = 1 hour. In production sync on every XRPL ledger close (~4s).
MERKLE_REBUILD_INTERVAL_MS=3600000

# Governance cycle length in seconds (e.g. 2592000 = 30 days)
CYCLE_DURATION_SECONDS=2592000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path for dev. Set to 'postgres' and DB_URL for production.
DB_PATH=./oracle.db

# ── Proof server ──────────────────────────────────────────────────────────────
PROOF_SERVER_PORT=3002
